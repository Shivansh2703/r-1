#!/usr/bin/python3

import rospy
import numpy as np
from audio_common_msgs.msg import AudioData
from audio_common_msgs.msg._AudioFormat import AudioFormat
from std_msgs.msg import Float32MultiArray
import pyaudio

class AudioSubscriber:

    def __init__(self):
        self.audio_data_subscriber = rospy.Subscriber('/audio_data', Float32MultiArray, self.audio_data_callback)
        self.py_audio = pyaudio.PyAudio()

    def audio_data_callback(self, msg):
	# Convert the Float32MultiArray to an AudioData message
        byte_data = np.array(msg.data, dtype=np.float32).tostring()
        audio_msg = AudioData()
        audio_msg.data = byte_data
        audio_msg.format = AudioFormat()
        audio_msg.format.sample_rate = 44100  # set the sample rate to 44.1 kHz
        audio_msg.format.num_channels = 1    # set the number of channels to 1
        audio_msg.format.encoding = 'f32'    # set the encoding to 32-bit floating point

        # Convert ROS AudioData to PyAudio format
        audio_data = audio_msg.data
        sample_width = audio_msg.encoding.split('_')[1]
        sample_rate = audio_msg.sample_rate
        channels = audio_msg.channels
        py_audio_format = self.py_audio.get_format_from_width(int(sample_width))
        stream = self.py_audio.open(format=py_audio_format,
                                    channels=int(channels),
                                    rate=int(sample_rate),
                                    output=True)
        # Play the audio data via system's audio device
        stream.write(audio_data)
        stream.close()

if __name__ == '__main__':
    rospy.init_node('audio_subscriber')
    audio_subscriber = AudioSubscriber()
    rospy.spin()
